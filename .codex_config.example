# icodex persistent configuration — template.
#
# Copy this file to `.codex_config` (which is git-ignored) and uncomment the
# variables you need:
#
#     cp .codex_config.example .codex_config
#     chmod 600 .codex_config
#
# Rules:
#   - Only ICODEX_*-prefixed `KEY=value` lines are honored; all other lines
#     (comments, blanks, disallowed keys) are ignored.
#   - The file is PARSED, never sourced — values cannot execute code.
#   - Precedence: built-in defaults < .codex_config < command-line flags.

# OpenAI API key — exported as OPENAI_API_KEY for codex. SECRET: this file is
# git-ignored and should be chmod 600. An OPENAI_API_KEY already in your shell
# takes precedence. Alternative: `codex login` (writes auth.json, also ignored).
#ICODEX_API_KEY=sk-...

# Run mode — bundles sandbox, approval, and managed permissions. Default: full-ask.
#   ro        read-only sandbox, asks before commands, no network/SSH.
#   safe      workspace-write, asks before commands, no network/SSH, .git writable.
#   full-ask  full filesystem access, still asks for risky actions, network + SSH read, .git writable.
#   full-auto full access, NEVER asks (no prompts at all), managed permissions off.
# Granular overrides below take precedence over the preset, per field.
#ICODEX_MODE=full-ask

# Approval policy override: untrusted | on-failure | on-request | never.
#ICODEX_APPROVAL=on-request

# Managed permission profile override: dev-safe | ssh-on-request | none
# (`none` removes the managed layer entirely, like full-auto).
#ICODEX_PERMISSIONS=ssh-on-request

# Filesystem sandbox override (granular): read-only | workspace-write | danger-full-access.
# Overrides only the sandbox field of ICODEX_MODE.
# The --full-access flag has higher precedence and forces danger-full-access for a
# single run (with a warning). An invalid value is rejected with an error.
#ICODEX_SANDBOX=workspace-write

# Route codex and its API/MCP traffic through a proxy.
#
# Use an HTTP CONNECT proxy URL here, even for HTTPS destinations. The `http://`
# scheme describes how Codex connects to the proxy itself; HTTPS requests to
# api.openai.com/chatgpt.com still go through CONNECT tunnels.
#
# Codex CLI may reject `https://` proxy URLs with "Proxy URL scheme not
# supported". If your upstream proxy only accepts TLS (`https://proxy:port`) or
# SOCKS, put a local HTTP proxy adapter in front of it and point ICODEX_PROXY at
# that adapter instead.
#
# Equivalent to a persisted `./icodex.sh --proxy <url>`.
#ICODEX_PROXY=http://proxy.local:8080

# Comma-separated host bypass list, exported as NO_PROXY (standard semantics):
# requests to these hosts skip the proxy. To disable the proxy for a single run,
# use the --no-proxy flag instead.
#ICODEX_NO_PROXY=localhost,127.0.0.1,github.com,githubusercontent.com,gitlab.com

# GitHub repo the codex binary is fetched from (default: openai/codex).
#ICODEX_REPO=openai/codex

# Force the release-asset platform instead of auto-detecting via uname.
# Rarely needed — only for cross-target installs.
#ICODEX_UNAME_S=Linux
#ICODEX_UNAME_M=x86_64

# Directory for the `icodex` symlink created on --install (default: ~/.local/bin).
# A leading ~/ is expanded. Put this dir on your PATH to run `icodex` directly.
#ICODEX_LINK_DIR=~/.local/bin

# Caveman token-compression of model output. Unset/off disables (ship default).
# When set, a small caveman instruction block is added to the isolated CODEX_HOME
# AGENTS.md (prompt-cached, ~0 per-turn token overhead) and a UserPromptSubmit hook
# is registered. Switch in-session with `/caveman lite|full|ultra|off`.
#   lite   drop filler only
#   full   drop articles + filler + pleasantries (recommended)
#   ultra  fragments + maximum abbreviation
#ICODEX_CAVEMAN_MODE=full

# iwiki MCP server (always on in every Codex home). All non-secret settings are
# fixed in the [mcp_servers.iwiki] block (see lib/iwiki/iwiki.sh): base dir, LLM
# base URL, embed model/dimensions. The ONLY key needed here is the secret API
# key, forwarded to the server as IWIKI_LLM_KEY via the config.toml `env_vars`
# allowlist. Keep it here (this file is git-ignored, chmod 600) — never in a
# tracked config.
#ICODEX_IWIKI_LLM_KEY=sk-...
