# icodex — CODEX_HOME (.codex-isolated) holds the isolated codex state.
# Whitelist: ignore everything, then re-include only curated, shareable artifacts.
.codex-isolated/*
!.codex-isolated/AGENTS.md
!.codex-isolated/AGENTS.override.md
!.codex-isolated/config.toml
!.codex-isolated/hooks.json
!.codex-isolated/hooks/
!.codex-isolated/hooks/**
.codex-isolated/hooks/__pycache__/
.codex-isolated/hooks/**/*.pyc
!.codex-isolated/caveman/
!.codex-isolated/caveman/**
!.codex-isolated/rules/
!.codex-isolated/rules/**
!.codex-isolated/agents/
!.codex-isolated/agents/**

# user skills travel in git; codex-managed system skills do not
!.codex-isolated/skills/
!.codex-isolated/skills/**
.codex-isolated/skills/.system/

# vendored plugins travel in git only when explicitly pinned
!.codex-isolated/plugins/
.codex-isolated/plugins/*
!.codex-isolated/plugins/cache/
.codex-isolated/plugins/cache/*

!.codex-isolated/plugins/cache/ikeniborn/
.codex-isolated/plugins/cache/ikeniborn/*
!.codex-isolated/plugins/cache/ikeniborn/loen/
!.codex-isolated/plugins/cache/ikeniborn/loen/**

!.codex-isolated/plugins/cache/openai-curated/
.codex-isolated/plugins/cache/openai-curated/*
!.codex-isolated/plugins/cache/openai-curated/superpowers/
!.codex-isolated/plugins/cache/openai-curated/superpowers/**

!.codex-isolated/plugins/cache/openai-curated-remote/
.codex-isolated/plugins/cache/openai-curated-remote/*
!.codex-isolated/plugins/cache/openai-curated-remote/github/
.codex-isolated/plugins/cache/openai-curated-remote/github/*
!.codex-isolated/plugins/cache/openai-curated-remote/github/0.1.8-2841cf9749ae/
!.codex-isolated/plugins/cache/openai-curated-remote/github/0.1.8-2841cf9749ae/**

.codex-isolated/plugins/.remote-plugin-install-staging/
.codex-isolated/plugins/**/.git/
.codex-isolated/plugins/**/.agents/
.codex-isolated/plugins/**/.codex-remote-plugin-install.json
.codex-isolated/plugins/**/*.lock
.codex-isolated/plugins/**/*.tmp

# Proxy URL + API key live here (chmod 600) — never commit
.codex_config

# Per-project CODEX_HOME directories — runtime state, never committed
.codex-homes/

# SDD scratch (briefs, reports, ledger) — never commit
.superpowers

# OS / editor noise
.DS_Store
*.swp

# Python verification artifacts
__pycache__/
*.pyc
