# icodex — CODEX_HOME (.codex-isolated) holds the isolated codex state.
# Whitelist: ignore everything, then re-include only curated, shareable artifacts.
.codex-isolated/*
!.codex-isolated/AGENTS.md
!.codex-isolated/AGENTS.override.md
!.codex-isolated/config.toml
!.codex-isolated/hooks.json
!.codex-isolated/hooks/
!.codex-isolated/hooks/**
.codex-isolated/hooks/__pycache__/
.codex-isolated/hooks/**/*.pyc
!.codex-isolated/caveman/
!.codex-isolated/caveman/**
!.codex-isolated/rules/
!.codex-isolated/rules/**

# user skills travel in git; codex-managed system skills do not
!.codex-isolated/skills/
!.codex-isolated/skills/**
.codex-isolated/skills/.system/

# installed plugins travel in git (no re-install on clone)
!.codex-isolated/plugins/
!.codex-isolated/plugins/**

# Proxy URL + API key live here (chmod 600) — never commit
.codex_config

# Per-project CODEX_HOME directories — runtime state, never committed
.codex-homes/

# SDD scratch (briefs, reports, ledger) — never commit
.superpowers

# OS / editor noise
.DS_Store
*.swp

# Python verification artifacts
__pycache__/
*.pyc
