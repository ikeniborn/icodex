{
  "$comment": "Template for project context detection output",
  "project_context": {
    "language": "{{language: python|javascript|typescript|go|rust|bash}}",
    "framework": "{{framework: fastapi|django|react|express|none}}",
    "test_framework": "{{test_framework: pytest|jest|go_test|none}}",
    "has_prd": "{{has_prd: boolean}}",
    "prd_path": "{{prd_path: string|null}}",
    "has_docs": "{{has_docs: boolean}}",
    "docs_llms_path": "{{docs_llms_path: string|null}}",
    "syntax_command": "{{syntax_command: from _shared/syntax-commands.json}}",
    "lint_command": "{{lint_command: optional}}",
    "code_style": "{{code_style: pep8|prettier|gofmt|none}}",
    "lat_initialized": "{{lat_initialized: boolean}}",
    "lat_sections": ["{{lat_section_ids}}"],
    "lat_index_path": "{{lat_index_path: lat.md/lat.md|null}}",
    "lat_summary": "{{lat_summary: string|null}}",
    "detected_files": {
      "config": ["{{config_files}}"],
      "source_dirs": ["{{source_directories}}"],
      "test_dirs": ["{{test_directories}}"]
    }
  }
}
